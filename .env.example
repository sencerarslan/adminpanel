# ────────────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ────────────────────────────────────────────────────────────
# API
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ────────────────────────────────────────────────────────────
# JWT
# ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
